# .env.example — Plantilla de variables de entorno
# Copiar este archivo como .env y completar los valores

# ================================
# VERTEX AI — Modo recomendado (con créditos GCP)
# ================================
# Habilita Vertex AI para embeddings y LLM (text-embedding-004 + ChatVertexAI)
# Requiere: gcloud auth application-default login
USE_VERTEX_AI=true
GCP_PROJECT_ID=tu-proyecto-gcp
GCP_REGION=us-central1

# ================================
# GOOGLE AI STUDIO — Alternativa gratuita
# ================================
# Solo se usa si USE_VERTEX_AI=false
# Obtén tu clave gratis en: https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY=tu_clave_aqui

# ================================
# GOOGLE DRIVE — Documentos corporativos (PDFs)
# ================================
# ID de la carpeta de Google Drive con los PDFs
# (se obtiene de la URL: https://drive.google.com/drive/folders/<FOLDER_ID>)
DRIVE_FOLDER_ID=tu_folder_id_aqui

# ================================
# OPCIONAL — Configuración del agente
# ================================
# LLM_MODEL=gemini-1.5-flash
# LLM_TEMPERATURE=0.1
# MEMORY_WINDOW_K=5
# AGENT_MAX_ITERATIONS=5

# ================================
# OPCIONAL — Configuración RAG
# ================================
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
# RAG_TOP_K=3
